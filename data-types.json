  "section_1_string_type": {
    "type": "String",
    "description": "UTF-8 text data, most common type in MongoDB",
    "syntax": "\"string value\"",
    "use_cases": [
      "Student names and IDs",
      "Email addresses and majors",
      "Locations and descriptions",
      "Enum-like values (status, type)"
    ],
    "examples": [
      {
        "field": "studentId",
        "value": "20260001",
        "type": "String",
        "query": "db.students.find({ studentId: '20260001' })",
        "use_case": "Unique identifier for student"
      },
      {
        "field": "major",
        "value": "Data Science",
        "type": "String",
        "query": "db.students.find({ major: 'Data Science' })",
        "use_case": "Filter students by field of study"
      },
      {
        "field": "name.first",
        "value": "Daksh",
        "type": "String",
        "query": "db.students.find({ 'name.first': 'Daksh' })",
        "use_case": "Search by first name"
      },
      {
        "field": "name.last",
        "value": "Chauhan",
        "type": "String",
        "query": "db.students.find({ 'name.last': 'Chauhan' })",
        "use_case": "Search by last name"
      }
    ],
    "storage": "UTF-8 encoded, no size limit per string",
    "performance": "Indexed strings provide fast lookups",
    "best_practices": [
      "Use lowercase for case-insensitive searches",
      "Index frequently searched strings",
      "Validate format (email, phone) at application level",
      "Use enums for fixed options"
    ]
  },
  "section_2_number_type": {
    "type": "Number (Integer and Double)",
    "description": "Numeric data - both integers and floating-point numbers",
    "subtypes": [
      "Int32 (32-bit integer)",
      "Int64 (64-bit integer)",
      "Double (64-bit floating-point)"
    ],
    "use_cases": [
      "Age and grade levels",
      "GPA and scores",
      "Counts and statistics",
      "Prices and amounts"
    ],
    "examples": [
      {
        "field": "age",
        "value": 20,
        "type": "Int32",
        "query": "db.students.find({ age: 20 })",
        "use_case": "Filter students by age"
      },
      {
        "field": "gpa",
        "value": 3.85,
        "type": "Double",
        "query": "db.students.find({ gpa: { $gte: 3.5 } })",
        "use_case": "Find honor students (GPA >= 3.5)"
      },
      {
        "field": "scholarshipDetails.amount",
        "value": 15000,
        "type": "Int32",
        "query": "db.students.find({ 'scholarshipDetails.amount': { $gte: 10000 } })",
        "use_case": "Find students with high scholarships"
      }
    ],
    "storage": "Int32: 4 bytes, Int64: 8 bytes, Double: 8 bytes",
    "performance": "Numeric comparisons and sorts are very fast",
    "best_practices": [
      "Use Int32 for values -2.1B to +2.1B",
      "Use Int64 for larger values",
      "Use Double for decimals (GPA, percentages)",
      "Index numeric fields for range queries"
    ]
  },
  "section_3_boolean_type": {
    "type": "Boolean",
    "description": "True/false values for flags and conditions",
    "values": [
      "true",
      "false"
    ],
    "use_cases": [
      "Feature flags (active, verified)",
      "Student status (international, on scholarship)",
      "Preferences and settings"
    ],
    "examples": [
      {
        "field": "isInternational",
        "value": false,
        "type": "Boolean",
        "query": "db.students.find({ isInternational: true })",
