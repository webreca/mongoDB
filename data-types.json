  "section_12_type_selection_guide": {
    "title": "Choosing the Right Data Type",
    "guide": [
      {
        "need": "Name, email, major, status",
        "type": "String",
        "reason": "Text data"
      },
      {
        "need": "Age, count, score, price",
        "type": "Number (Int32 or Double)",
