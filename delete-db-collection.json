      "Drop Collection: Delete one collection (all documents)"
    ],
    "key_difference": {
      "dropDatabase": "Removes ALL collections and data in database",
      "dropCollection": "Removes single collection only"
    }
  },
  "section_1_drop_database": {
    "title": "Drop Database - Delete Entire Database",
    "definition": "Removes the entire database including all collections",
    "danger_level": "⚠️⚠️⚠️ MOST DANGEROUS - ALL DATA LOST",
    "syntax": "db.dropDatabase()",
    "requirements": [
      "Connected to database to drop",
      "Sufficient permissions (admin role typically)"
    ],
    "example_database": "school_db",
    "example_collections_deleted": [
      "students (60 records lost)",
      "teachers",
      "courses",
      "grades",
      "Any other collections in database"
    ],
    "code_example": {
      "step1_show_databases": "show dbs",
      "step2_use_database": "use school_db",
      "step3_verify_database": "db.getName()",
      "step4_verify_collections": "show collections",
      "step5_execute_drop": "db.dropDatabase()",
      "result": "Database completely removed with all data"
    },
    "return_value": {
      "success": "{ 'ok': 1 }",
      "database_name_after": "Database no longer exists"
    },
    "safety_procedure": [
      {
        "step": 1,
        "action": "BACKUP FIRST",
        "command": "mongodump --db school_db --out backup_school/",
        "critical": "MANDATORY - No recovery without backup"
      },
      {
        "step": 2,
        "action": "Verify you are in correct database",
        "command": "db.getName()",
        "verify": "Must show 'school_db' or target database"
      },
      {
        "step": 3,
        "action": "List all collections first",
        "command": "show collections",
        "note": "See what will be deleted"
      },
      {
        "step": 4,
        "action": "Count total documents",
        "command": "db.students.countDocuments()",
        "note": "Verify scale of loss"
      },
      {
        "step": 5,
        "action": "Confirm with stakeholders",
        "command": "Email/message team: 'Deleting school_db on 2024-06-23'",
        "critical": "Get approval before proceeding"
      },
      {
        "step": 6,
        "action": "Execute drop",
        "command": "db.dropDatabase()",
        "warning": "Point of no return"
      },
      {
        "step": 7,
        "action": "Verify deletion",
        "command": "show dbs",
        "verify": "school_db should not appear"
      }
    ],
    "scenario_example": {
      "situation": "Development environment cleanup",
      "database": "school_db_dev",
      "reason": "End of testing cycle, need fresh database",
      "process": [
        "1. Confirm no production data",
        "2. Backup (optional for dev, but good practice)",
        "3. List collections: show collections",
        "4. Execute: db.dropDatabase()",
        "5. Verify: show dbs (school_db_dev should be gone)"
      ],
      "time_taken": "Milliseconds for entire database"
    },
    "recovery": "IMPOSSIBLE without backup - Use mongorestore if backup exists"
  },
  "section_2_drop_collection": {
    "title": "Drop Collection - Delete Single Collection",
    "definition": "Removes a single collection from the database",
    "danger_level": "⚠️⚠️ VERY DANGEROUS - Collection data lost, database remains",
    "syntax": "db.collection.drop()",
    "requirements": [
      "Connected to database",
      "Collection name specified"
    ],
    "example_collection": "students",
    "example_data_lost": "60 student records permanently deleted",
    "code_example": {
      "step1_use_database": "use school_db",
      "step2_list_collections": "show collections",
      "step3_count_documents": "db.students.countDocuments()",
      "step4_execute_drop": "db.students.drop()",
      "result": "students collection and all 60 records deleted"
    },
    "return_value": {
      "success": "true (if collection exists)",
      "not_exists": "false (if collection doesn't exist)"
    },
    "safety_procedure": [
      {
        "step": 1,
        "action": "BACKUP FIRST",
        "command": "mongodump --db school_db --collection students --out backup_students/",
        "critical": "MANDATORY - No recovery without backup"
      },
      {
        "step": 2,
        "action": "Verify you are in correct database",
        "command": "db.getName()",
        "verify": "Must show 'school_db'"
      },
      {
        "step": 3,
        "action": "Verify correct collection",
        "command": "db.students.findOne()",
        "note": "Confirm this is the right collection"
      },
      {
        "step": 4,
        "action": "Count documents to be deleted",
        "command": "db.students.countDocuments()",
        "verify": "Expect 60 documents"
      },
      {
        "step": 5,
        "action": "Check for recent activity",
        "command": "db.students.find().sort({ _id: -1 }).limit(1)",
        "note": "Verify no recent inserts/updates"
      },
      {
        "step": 6,
        "action": "Confirm with team",
        "command": "Get written approval before deletion",
        "critical": "Document who authorized"
      },
      {
        "step": 7,
        "action": "Execute drop",
        "command": "db.students.drop()",
        "warning": "Point of no return"
      },
      {
        "step": 8,
        "action": "Verify deletion",
        "command": "show collections",
        "verify": "students should not appear"
      }
    ],
    "scenario_examples": [
      {
        "scenario": "Delete old course records",
        "collection": "courses_2020",
        "reason": "Archive old data, reduce storage",
        "process": [
          "1. Backup: mongodump --collection courses_2020",
          "2. Count: db.courses_2020.countDocuments() → 500 docs",
          "3. Confirm archival location",
          "4. Drop: db.courses_2020.drop()",
          "5. Verify: show collections (courses_2020 gone)"
        ],
        "document_count": 500
      },
      {
        "scenario": "Delete test/temp collection",
        "collection": "temp_import",
        "reason": "Cleanup after data migration test",
        "process": [
          "1. Verify temp data (not production)",
          "2. Count: db.temp_import.countDocuments() → 2000 docs",
          "3. Drop: db.temp_import.drop()",
          "4. Verify gone"
        ],
        "document_count": 2000
      }
    ],
    "recovery": "IMPOSSIBLE without backup - Use mongorestore if backup exists"
  },
  "section_3_comparison_database_vs_collection": {
    "title": "Drop Database vs Drop Collection",
    "comparison_table": [
      {
        "aspect": "What is deleted",
        "dropDatabase": "Entire database + ALL collections",
        "dropCollection": "Single collection only"
      },
      {
        "aspect": "Database remains",
        "dropDatabase": "NO - Database is gone",
        "dropCollection": "YES - Database intact, other collections remain"
      },
      {
        "aspect": "Other collections",
        "dropDatabase": "ALL deleted",
        "dropCollection": "Other collections unaffected"
      },
      {
        "aspect": "Syntax",
        "dropDatabase": "db.dropDatabase()",
        "dropCollection": "db.collectionName.drop()"
      },
      {
        "aspect": "Use case",
        "dropDatabase": "Complete environment cleanup",
        "dropCollection": "Remove specific old data"
      },
      {
        "aspect": "Danger level",
        "dropDatabase": "⚠️⚠️⚠️ MOST DANGEROUS",
        "dropCollection": "⚠️⚠️ Very dangerous"
      },
      {
        "aspect": "Frequency",
        "dropDatabase": "Rarely (dev cleanup only)",
        "dropCollection": "More common (archival, cleanup)"
      }
    ]
  },
  "section_4_alternatives_to_deletion": {
    "title": "Safer Alternatives Instead of Deletion",
    "why_consider": "Deletion is permanent - consider alternatives first",
    "alternative_1_soft_delete": {
      "name": "Soft Delete",
      "description": "Mark records as deleted instead of removing",
      "advantage": "Reversible, keeps audit trail",
      "implementation": "Add 'deleted: true' field",
      "code_example": {
        "instead_of_drop": "db.students.drop()",
        "use_soft_delete": "db.students.updateMany({}, { $set: { deleted: true } })",
        "query_active": "db.students.find({ deleted: false })"
      },
      "recovery": "Set deleted: false to undelete",
      "cost": "Slightly more storage, but reversible"
    },
    "alternative_2_archive": {
      "name": "Archive to Different Collection",
      "description": "Move data to archive collection before deletion",
      "advantage": "Keep historical data accessible",
      "implementation": "Copy to archive, then drop original",
      "code_example": {
        "step1_create_archive": "db.createCollection('students_archive_2024')",
        "step2_copy_data": "db.students_archive_2024.insertMany(db.students.find().toArray())",
        "step3_drop_original": "db.students.drop()",
        "recovery": "db.students.insertMany(db.students_archive_2024.find().toArray())"
      },
      "recovery": "Restore from archive collection",
      "cost": "Double storage temporarily, but data preserved"
    },
    "alternative_3_export_backup": {
      "name": "Export to File Before Deletion",
      "description": "Export collection/database to JSON or BSON file",
      "advantage": "External backup, offline access",
      "implementation": "Use mongodump or mongoexport",
      "code_example": {
        "export_json": "mongoexport --db school_db --collection students --out students_backup.json",
        "export_bson": "mongodump --db school_db --collection students --out backup/",
        "drop": "db.students.drop()",
        "recovery": "mongorestore --db school_db --collection students backup/school_db/students.bson"
      },
      "recovery": "Restore from backup file",
      "cost": "Minimal storage (compressed), portable"
    },
    "alternative_4_separate_database": {
      "name": "Move to Separate Database",
      "description": "Instead of drop, move active data to new database",
      "advantage": "Keep old data accessible, clean production",
      "implementation": "Copy to new DB, then drop old",
      "code_example": {
        "current": "school_db (has old data mixed in)",
        "solution": "Create school_db_active (clean data) + school_db_archive (old data)",
        "then_drop": "Drop old school_db"
      },
      "recovery": "Both databases still exist",
      "cost": "More storage, but organized"
    },
    "recommendation": "Always use alternative if you might need data again"
  },
  "section_5_backup_recovery": {
    "title": "Backup and Recovery Procedures",
    "mongodump_backup": {
      "description": "Backup entire database or collection",
      "backup_database": "mongodump --db school_db --out backup_school_db/",
      "backup_collection": "mongodump --db school_db --collection students --out backup_students/",
      "backup_all": "mongodump --out backup_all/",
      "timing": "Takes ~5-30 seconds for 60 documents",
      "storage": "BSON format, compressed"
    },
    "mongorestore_recovery": {
      "description": "Restore from mongodump backup",
      "restore_database": "mongorestore --db school_db backup_school_db/school_db/",
      "restore_collection": "mongorestore --db school_db --collection students backup_students/school_db/students.bson",
      "restore_all": "mongorestore backup_all/",
      "timing": "~5-30 seconds to restore"
    },
    "mongoexport_json": {
      "description": "Export to JSON for manual inspection",
      "export": "mongoexport --db school_db --collection students --out students.json",
      "view": "Human-readable JSON format",
      "import": "mongoimport --db school_db --collection students < students.json"
    },
    "backup_automation": {
      "recommendation": "Automate daily backups",
      "example_script": "0 2 * * * mongodump --db school_db --out /backups/school_db_$(date +%Y%m%d)/",
      "retention": "Keep 30 days of backups",
      "test_recovery": "Test restore monthly"
    }
  },
