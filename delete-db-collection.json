      "collections": "students_new (incomplete, corrupted)",
      "reason": "Bad data in migration process",
      "process": [
        "1. Check data integrity: db.students_new.find().limit(5)",
        "2. Data is corrupted/incomplete",
        "3. Drop failed collection: db.students_new.drop()",
        "4. Rollback from backup: mongorestore backup_students/",
        "5. Verify restoration: db.students.countDocuments()",
        "6. Verify data integrity: Random spot checks"
      ],
      "time": "Minutes (restore + verification)",
      "risk": "MEDIUM (but backup prevents loss)"
    },
    "scenario_4_disaster_cleanup": {
      "title": "Accidental Deletion - Recovery",
      "situation": "Student deletes data accidentally",
      "what_happened": "Ran: db.students.drop()",
      "when_discovered": "5 minutes later",
      "process": [
        "1. DO NOT panic - backup should exist",
        "2. Find latest backup: ls -la backup_students/",
        "3. Restore: mongorestore --db school_db backup_students/school_db/",
        "4. Verify: db.students.countDocuments() → 60 ✓",
        "5. Check timestamp of recovered data",
        "6. Review what changed since backup"
      ],
      "time": "Minutes (restore is fast)",
      "risk": "HIGH (but recovery is possible with backup)"
    }
  },
  "section_7_critical_safety_rules": {
    "rule_1_always_backup": {
      "rule": "ALWAYS BACKUP BEFORE DROP",
      "why": "Only way to recover from permanent deletion",
      "command": "mongodump --db school_db --out backup_$(date +%Y%m%d_%H%M%S)/",
      "requirement": "MANDATORY for production"
    },
    "rule_2_verify_database": {
      "rule": "VERIFY CORRECT DATABASE",
      "why": "Can't delete from 2 databases simultaneously",
      "command": "db.getName()",
      "requirement": "Must match target exactly"
    },
    "rule_3_count_documents": {
      "rule": "COUNT DOCUMENTS FIRST",
      "why": "Verify scale of deletion",
      "command": "db.students.countDocuments()",
      "requirement": "Know what you're deleting"
    },
    "rule_4_get_approval": {
      "rule": "GET WRITTEN APPROVAL",
      "why": "Accountability, prevent mistakes",
      "evidence": "Email/Slack from manager",
      "requirement": "Especially for production"
    },
    "rule_5_document_deletion": {
      "rule": "DOCUMENT THE DELETION",
      "why": "Audit trail for compliance",
      "record": "Who, when, why, what backup",
      "requirement": "Required for production"
    },
    "rule_6_no_undo_button": {
      "rule": "DELETION IS PERMANENT",
      "why": "No second chances",
      "point_of_no_return": "When db.drop() executes",
      "requirement": "Proceed with extreme caution"
    }
  },
  "section_8_common_mistakes": {
    "mistake_1_forgetting_backup": {
      "mistake": "Deleting without backup",
      "scenario": "Need to free up space, drop old collection without backup",
      "result": "❌ Data permanently lost, unrecoverable",
      "fix": "Always mongodump before drop",
      "lesson": "Backup is insurance policy"
    },
    "mistake_2_wrong_database": {
      "mistake": "Wrong database context",
      "scenario": "Meant to drop school_db_test but was in school_db",
      "result": "❌ Deleted production data instead",
      "prevention": "Always verify: db.getName()",
      "lesson": "Double-check context before drop"
    },
    "mistake_3_no_verification": {
      "mistake": "Not verifying after drop",
      "scenario": "Drop command ran, but didn't check if actually deleted",
      "result": "😕 May have failed silently",
      "verification": "show collections / show dbs after drop",
      "lesson": "Verify deletion completed"
    },
    "mistake_4_no_approval": {
      "mistake": "Deleting without getting approval",
      "scenario": "Team member deletes shared collection",
      "result": "❌ Other team members lost access",
      "solution": "Get written approval first",
      "lesson": "Communication prevents disasters"
    },
    "mistake_5_wrong_syntax": {
      "mistake": "Wrong method name",
      "bad_syntax": "db.students.remove({}) instead of db.students.drop()",
      "result": "May not drop collection entirely",
      "correct_syntax": "db.students.drop()",
      "lesson": "Use correct command"
    }
  },
