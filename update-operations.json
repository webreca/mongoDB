{
  "title": "MongoDB Update Operations - updateOne vs updateMany Guide",
  "description": "Complete comparison of update operations with use cases and operators",
  "date": "2024-06-23",
  "totalStudents": 60,
  "quick_comparison": {
    "updateOne": {
      "updates": "Single document (first match)",
      "typical_count": "1 document",
      "best_for": "Individual record updates",
      "performance": "Fast for single",
      "syntax": "db.collection.updateOne(filter, update)",
      "returns": "modifiedCount, matchedCount"
    },
    "updateMany": {
      "updates": "All matching documents",
      "typical_count": "2 to many",
      "best_for": "Bulk updates",
      "performance": "Efficient for bulk",
      "syntax": "db.collection.updateMany(filter, update)",
      "returns": "modifiedCount, matchedCount"
    }
  },
  "section_1_updateOne": {
    "title": "updateOne() - Single Document Update",
    "description": "Update first matching document only",
    "syntax": "db.collection.updateOne(filter, update, options)",
    "returns": {
      "acknowledged": true,
      "matchedCount": 1,
      "modifiedCount": 1
    },
    "characteristics": [
      "Updates exactly 1 document (first match)",
      "Other matching documents untouched",
      "Fast for single record",
      "Good for individual changes",
      "Returns modifiedCount and matchedCount"
    ],
    "basic_examples": [
      {
        "example": "Update student GPA",
        "command": "db.students.updateOne({ studentId: 20260001 }, { $set: { gpa: 3.95 } })",
        "result": "Daksh Chauhan's GPA updated to 3.95",
        "use_case": "Update grade for one student"
      },
      {
        "example": "Add skill to student",
        "command": "db.students.updateOne({ studentId: 20260001 }, { $push: { skills: 'Docker' } })",
        "result": "Docker added to Daksh's skills array",
        "use_case": "Add new skill to one student"
      },
      {
        "example": "Update nested field",
        "command": "db.students.updateOne({ studentId: 20260001 }, { $set: { 'scholarshipDetails.amount': 20000 } })",
        "result": "Scholarship amount updated",
        "use_case": "Update scholarship for one student"
      }
    ],
    "operators_used": [
      {
        "operator": "$set",
        "example": "{ $set: { gpa: 3.95 } }",
        "use_case": "Set field value"
      },
      {
        "operator": "$inc",
        "example": "{ $inc: { age: 1 } }",
        "use_case": "Increment numeric field"
      },
      {
        "operator": "$push",
        "example": "{ $push: { skills: 'Docker' } }",
        "use_case": "Add to array"
      },
      {
        "operator": "$pull",
        "example": "{ $pull: { skills: 'Python' } }",
        "use_case": "Remove from array"
      },
      {
        "operator": "$unset",
        "example": "{ $unset: { scholarshipDetails: '' } }",
        "use_case": "Remove field"
      }
    ],
    "real_world_scenarios": [
      {
        "scenario": "Update Student Grade",
        "description": "Teacher enters grade for student's course",
        "code": "db.students.updateOne({ studentId: 20260001, 'courses.courseCode': 'DS-401' }, { $set: { 'courses.$.grade': 'A+' } })"
      },
      {
        "scenario": "Increment Age on Birthday",
        "description": "Student has birthday",
        "code": "db.students.updateOne({ studentId: 20260001 }, { $inc: { age: 1 } })"
      },
      {
        "scenario": "Add Skill",
        "description": "Student learns new technology",
        "code": "db.students.updateOne({ studentId: 20260001 }, { $push: { skills: 'Kubernetes' } })"
      },
      {
        "scenario": "Update Profile",
        "description": "Student changes major",
        "code": "db.students.updateOne({ studentId: 20260001 }, { $set: { major: 'Cloud Computing' } })"
      }
    ],
    "performance_characteristics": {
      "time_per_update": "~1-5ms",
      "ideal_for": "Single record updates",
      "not_ideal_for": "Bulk updates (slow when called repeatedly)"
    }
  },
  "section_2_updateMany": {
    "title": "updateMany() - Multiple Document Update",
    "description": "Update all matching documents",
    "syntax": "db.collection.updateMany(filter, update, options)",
    "returns": {
      "acknowledged": true,
      "matchedCount": "N",
      "modifiedCount": "N"
    },
    "characteristics": [
      "Updates all matching documents",
      "Single database operation",
      "Fast for bulk updates",
      "Returns total matched and modified counts",
      "Essential for batch operations"
    ],
    "basic_examples": [
      {
        "example": "Update all international students",
        "command": "db.students.updateMany({ isInternational: true }, { $set: { visaStatus: 'F-1' } })",
        "result": "30 international students updated",
        "documents_updated": 30
      },
      {
        "example": "Update all honor students",
        "command": "db.students.updateMany({ gpa: { $gte: 3.9 } }, { $set: { status: 'honor' } })",
        "result": "17 honor students updated",
        "documents_updated": 17
      },
      {
        "example": "Remove field from all documents",
        "command": "db.students.updateMany({}, { $unset: { tempField: '' } })",
        "result": "All 60 students updated (field removed)",
        "documents_updated": 60
      }
    ],
    "real_world_scenarios": [
      {
        "scenario": "Update All International Students",
        "description": "New visa requirement implemented",
        "code": "db.students.updateMany({ isInternational: true }, { $set: { requiresVisa: true, visaType: 'F-1' } })"
      },
      {
        "scenario": "Graduation Update",
        "description": "Class of 2024 graduates",
        "code": "db.students.updateMany({ graduationYear: 2024 }, { $set: { status: 'graduated' } })"
      },
      {
        "scenario": "Semester Grade Finalization",
        "description": "End of semester, finalize all student grades",
        "code": "db.students.updateMany({ semester: 'Spring2024' }, { $set: { finalGradePosted: true, gradePostDate: new Date() } })"
      },
      {
        "scenario": "Add Default Course to All Students",
        "description": "All students required to take core course",
        "code": "db.students.updateMany({}, { $push: { courses: { courseCode: 'CORE-100', credits: 3, grade: 'Not Started' } } })"
      },
      {
        "scenario": "Remove Expired Scholarships",
        "description": "Scholarship period ended",
        "code": "db.students.updateMany({ 'scholarshipDetails.endDate': { $lt: new Date() } }, { $set: { scholarshipDetails: null } })"
      }
    ],
    "performance_characteristics": {
      "time_for_30_updates": "~10-30ms",
      "time_for_60_updates": "~20-50ms",
      "ideal_for": "Bulk operations, multiple records",
      "speedup_vs_loop": "2-3x faster than repeated updateOne calls"
    }
  },
  "section_3_detailed_comparison": {
    "comparison_table": [
      {
        "aspect": "Documents Updated",
        "updateOne": "1 document (first match)",
        "updateMany": "All matching documents",
        "impact": "updateOne for single, updateMany for bulk"
      },
      {
        "aspect": "Matched vs Modified",
        "updateOne": "May match 1 but modify 0 (no change)",
        "updateMany": "May match 30 but modify 20 (if only some changed)",
        "impact": "Check both counts for verification"
      },
      {
        "aspect": "Performance",
        "updateOne": "~1-5ms per update",
        "updateMany": "~20-50ms for 30 updates (single call)",
        "impact": "updateMany much faster for bulk"
      },
      {
        "aspect": "Other Documents",
        "updateOne": "Other matches not touched",
        "updateMany": "All matches updated",
        "impact": "Be careful with updateMany filter"
      },
      {
        "aspect": "Typical Use",
        "updateOne": "Single record changes",
        "updateMany": "Bulk operations",
        "impact": "Choose based on scope"
      },
      {
        "aspect": "Filter Specificity",
        "updateOne": "Can use broad filter",
        "updateMany": "Must be very careful with filter",
        "impact": "updateMany risk if filter is wrong"
      }
    ]
  },
  "section_4_operators_reference": {
    "set_operator": {
      "syntax": "{ $set: { field: value } }",
      "description": "Set field value",
      "examples": [
        {
          "example": "Update GPA",
          "command": "db.students.updateOne({ studentId: 20260001 }, { $set: { gpa: 3.95 } })",
          "result": "GPA updated to 3.95"
        },
        {
          "example": "Update nested field",
          "command": "db.students.updateOne({ studentId: 20260001 }, { $set: { 'name.first': 'Daksh Kumar' } })",
          "result": "First name updated"
        },
        {
          "example": "Update multiple fields",
          "command": "db.students.updateOne({ studentId: 20260001 }, { $set: { gpa: 3.95, age: 21, status: 'senior' } })",
          "result": "Multiple fields updated at once"
        }
      ]
    },
    "inc_operator": {
      "syntax": "{ $inc: { field: number } }",
      "description": "Increment numeric field",
      "examples": [
        {
          "example": "Increment age",
          "command": "db.students.updateOne({ studentId: 20260001 }, { $inc: { age: 1 } })",
          "result": "Age increased from 20 to 21"
        },
        {
          "example": "Decrement (negative increment)",
          "command": "db.students.updateOne({ studentId: 20260001 }, { $inc: { enrolledCourses: -1 } })",
          "result": "Course count decreased by 1"
        }
      ]
    },
    "push_operator": {
      "syntax": "{ $push: { arrayField: value } }",
      "description": "Add element to array",
      "examples": [
        {
          "example": "Add skill",
          "command": "db.students.updateOne({ studentId: 20260001 }, { $push: { skills: 'Docker' } })",
          "result": "Docker added to skills array"
        },
        {
          "example": "Add multiple values",
          "command": "db.students.updateOne({ studentId: 20260001 }, { $push: { skills: { $each: ['Docker', 'Kubernetes'] } } })",
          "result": "Multiple skills added"
        }
      ]
    },
    "pull_operator": {
      "syntax": "{ $pull: { arrayField: value } }",
      "description": "Remove element from array",
      "examples": [
        {
          "example": "Remove skill",
          "command": "db.students.updateOne({ studentId: 20260001 }, { $pull: { skills: 'Python' } })",
          "result": "Python removed from skills array"
        },
        {
          "example": "Remove by condition",
          "command": "db.students.updateOne({ studentId: 20260001 }, { $pull: { courses: { grade: 'F' } } })",
          "result": "Failed courses removed"
        }
      ]
    },
    "unset_operator": {
      "syntax": "{ $unset: { field: '' } }",
      "description": "Remove field from document",
      "examples": [
        {
          "example": "Remove scholarship details",
          "command": "db.students.updateOne({ studentId: 20260001 }, { $unset: { scholarshipDetails: '' } })",
          "result": "scholarshipDetails field removed"
        }
      ]
    }
  },
  "section_5_real_world_scenarios": {
    "scenario_1_update_single_grade": {
      "title": "Update Single Student Grade",
      "requirement": "Teacher enters grade for one student's course",
      "recommended": "updateOne",
      "code": "db.students.updateOne({ studentId: 20260001, 'courses.courseCode': 'DS-401' }, { $set: { 'courses.$.grade': 'A+' } })",
      "why": "Only one student's grade needs updating"
    },
    "scenario_2_update_all_international": {
      "title": "Update All International Students",
      "requirement": "New visa requirement for all international students",
      "recommended": "updateMany",
      "code": "db.students.updateMany({ isInternational: true }, { $set: { visaType: 'F-1', requiresVisa: true } })",
      "result": "30 international students updated",
      "why": "All matching students need same update"
    },
    "scenario_3_end_of_semester": {
      "title": "End of Semester - Finalize Grades",
      "requirement": "Finalize grades for all students",
      "recommended": "updateMany",
      "code": "db.students.updateMany({}, { $set: { finalGradePosted: true, gradePostDate: new Date() } })",
      "result": "All 60 students updated",
      "why": "Bulk operation affecting all students"
    },
    "scenario_4_student_changes_major": {
      "title": "Student Changes Major",
      "requirement": "One student switches to different major",
      "recommended": "updateOne",
      "code": "db.students.updateOne({ studentId: 20260001 }, { $set: { major: 'Cloud Computing' } })",
      "why": "Only one student's major changes"
    },
    "scenario_5_scholarship_renewal": {
      "title": "Renew Scholarships for Eligible Students",
      "requirement": "Renew scholarships for students with GPA >= 3.5",
      "recommended": "updateMany",
      "code": "db.students.updateMany({ gpa: { $gte: 3.5 }, 'scholarshipDetails.renewable': true }, { $set: { 'scholarshipDetails.renewalDate': new Date() } })",
      "result": "Many students' scholarships renewed",
      "why": "Multiple students meeting criteria get updated"
    }
  },
  "section_6_performance_analysis": {
    "scenario_update_30_international_students": {
      "requirement": "Update all 30 international students with visa status",
      "method_1_updateOne_loop": {
        "approach": "Loop through all international students, updateOne each",
        "code": "internationalStudents.forEach(student => { db.students.updateOne({ studentId: student.studentId }, { $set: { visaStatus: 'F-1' } }) })",
        "time_estimate": "30-150ms (30 separate operations)",
        "database_trips": 30,
        "network_calls": 30
      },
      "method_2_updateMany": {
        "approach": "Single updateMany for all international students",
        "code": "db.students.updateMany({ isInternational: true }, { $set: { visaStatus: 'F-1' } })",
        "time_estimate": "10-30ms (1 operation)",
        "database_trips": 1,
        "network_calls": 1
      },
      "performance_winner": "updateMany - 2-3x faster",
      "speedup_calculation": "30 calls × ~2-5ms = 60-150ms vs 1 call × ~10-30ms"
    },
    "scenario_update_single_student": {
      "requirement": "Update single student's GPA",
      "method_1_updateOne": {
        "code": "db.students.updateOne({ studentId: 20260001 }, { $set: { gpa: 3.95 } })",
        "time_estimate": "1-5ms",
        "approach": "Direct update"
      },
      "method_2_updateMany": {
        "code": "db.students.updateMany({ studentId: 20260001 }, { $set: { gpa: 3.95 } })",
        "time_estimate": "2-8ms",
        "approach": "Bulk operation syntax (unnecessary)"
      },
      "performance_winner": "updateOne - simpler, slightly faster",
      "difference": "Minimal (~1-3ms)"
    }
  },
  "section_7_when_to_use": {
    "use_updateOne_when": [
      "Updating single student record",
      "Change one student's grade",
      "Update individual user profile",
      "Add skill to one student",
      "Increment age for one student",
      "Remove scholarship from one student",
      "Certainty that only one should be updated"
    ],
    "use_updateMany_when": [
      "Updating multiple matching students",
      "All international students (30)",
      "All honor students (17)",
      "All students graduating",
      "Semester-wide updates",
      "Bulk status changes",
      "When uncertainty about match count"
    ]
  },
  "section_8_best_practices": [
    {
      "practice": "Use updateOne for single records",
      "example": "db.students.updateOne({ studentId: id }, { $set: { gpa: value } })",
      "benefit": "Clear intent, prevents accidental bulk updates"
    },
    {
      "practice": "Use updateMany for bulk operations",
      "example": "db.students.updateMany({ isInternational: true }, { $set: { visaStatus: 'F-1' } })",
      "benefit": "2-3x faster than repeated updateOne"
    },
    {
      "practice": "Check modifiedCount after update",
      "example": "const result = db.students.updateOne({...}); console.log(result.modifiedCount)",
      "benefit": "Verify update actually changed something"
    },
    {
      "practice": "Be careful with updateMany filter",
      "example": "Test filter with find() first before updateMany()",
      "benefit": "Prevent accidental bulk updates"
    },
    {
      "practice": "Use specific fields in $set",
      "example": "{ $set: { 'scholarshipDetails.amount': 20000 } }",
      "benefit": "Only update what needs changing"
    },
    {
      "practice": "Combine operators in single update",
      "example": "{ $set: { gpa: 3.95 }, $push: { skills: 'Docker' } }",
      "benefit": "Single database operation for multiple changes"
    }
  ],
  "student_data_examples": {
    "updateOne_examples": [
      {
        "scenario": "Daksh Chauhan's GPA",
        "filter": "{ studentId: 20260001 }",
        "update": "{ $set: { gpa: 3.95 } }",
        "result": "GPA changed from 3.85 to 3.95"
      },
      {
        "scenario": "Add Docker to Daksh's skills",
        "filter": "{ studentId: 20260001 }",
        "update": "{ $push: { skills: 'Docker' } }",
        "result": "Docker added to skills array"
      }
    ],
    "updateMany_examples": [
      {
        "scenario": "Update all 30 international students",
        "filter": "{ isInternational: true }",
        "update": "{ $set: { visaStatus: 'F-1' } }",
        "result": "30 students updated"
      },
      {
        "scenario": "Update all 17 honor students",
        "filter": "{ gpa: { $gte: 3.9 } }",
        "update": "{ $set: { status: 'honor' } }",
        "result": "17 students updated"
      },
      {
        "scenario": "Update all 60 students (add field)",
        "filter": "{}",
        "update": "{ $set: { updated: true, updateDate: new Date() } }",
        "result": "All 60 students updated"
      }
    ]
  },
  "summary": {
    "updateOne": "Use for single document updates (changing one student's record)",
    "updateMany": "Use for multiple document updates (bulk operations on matching students)",
    "performance": "updateMany 2-3x faster for bulk operations",
    "rule": "1 document? updateOne. Multiple documents? updateMany",
    "key_point": "Choose based on scope: single vs multiple records"
  }
}
