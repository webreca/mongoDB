  "summary": {
    "definition": "Comparison operators filter documents by comparing field values",
    "operators": [
      "$eq - Equal",
      "$ne - Not equal",
      "$gt - Greater than",
      "$gte - Greater than or equal",
      "$lt - Less than",
      "$lte - Less than or equal",
      "$in - In array",
      "$nin - Not in array"
    ],
    "key_uses": [
      "Exact matching ($eq, $in)",
      "Range queries ($gt, $gte, $lt, $lte)",
      "Exclusion ($ne, $nin)",
      "Multiple value matching ($in)"
    ],
    "best_practice": "Index frequently queried fields, use $in instead of $or, combine operators for ranges",
    "performance": "Most operators support indexing except $ne and $nin"
  }
