  "summary": {
    "core_concept": "Query and analyze documents based on dates and time ranges",
    "key_operators": "$gt, $lt, $gte, $lte for comparison; $year, $month for extraction",
    "best_practice": "Use ISODate, store UTC, index date fields, use ranges not exact equality",
    "common_pattern": "{ dateField: { $gte: startDate, $lt: endDate } }",
    "performance": "Index date fields for faster range queries",
    "timezone_note": "Store all dates in UTC, convert on display",
