  },
  "section_10_best_practices": {
    "practice_1_always_use_isodate": {
      "rule": "Store dates as ISODate, not strings",
      "good": "new Date('2024-06-23')",
      "avoid": "'2024-06-23' (string)",
      "why": "Range queries don't work on strings"
    },
    "practice_2_store_utc": {
      "rule": "Store all dates in UTC",
      "good": "new Date() (UTC)",
      "avoid": "Storing local time",
      "why": "Consistent across timezones"
    },
    "practice_3_index_date_fields": {
      "rule": "Index frequently queried date fields",
      "example": "db.students.createIndex({ enrollmentDate: 1 })",
      "why": "Range queries are much faster"
    },
    "practice_4_use_date_arithmetic": {
      "rule": "Use $dateAdd/$dateSubtract instead of manual math",
      "good": "{ $dateAdd: { startDate: '$date', unit: 'day', amount: 30 } }",
      "avoid": "New Date(date.getTime() + 30*24*60*60*1000)",
      "why": "Handles edge cases, more readable"
    },
    "practice_5_precision_awareness": {
      "rule": "Be aware of date precision (milliseconds)",
      "note": "Dates stored to millisecond precision",
      "impact": "Exact equality rare, use ranges instead"
    }
  },
  "section_11_common_mistakes": {
    "mistake_1_string_dates": {
      "mistake": "Query on string dates",
      "wrong": "db.students.find({ date: { $gt: '2024-06-23' } })",
      "right": "db.students.find({ date: { $gt: new Date('2024-06-23') } })",
      "impact": "String comparison doesn't work for dates"
    },
    "mistake_2_ignoring_utc": {
      "mistake": "Forget to convert from local time",
      "problem": "Queries off by timezone offset",
      "solution": "All dates in UTC, convert on display"
    },
    "mistake_3_no_index": {
      "mistake": "Query dates without index",
      "problem": "Full collection scan (slow)",
      "solution": "createIndex({ dateField: 1 })"
    },
    "mistake_4_exact_equality": {
      "mistake": "Use $eq for date matching",
      "problem": "Unlikely exact match (to millisecond)",
      "solution": "Use range with $gte and $lt"
    },
    "mistake_5_timezone_confusion": {
      "mistake": "Assume stored date is in local time",
      "problem": "Wrong results from timezone-aware queries",
      "solution": "Remember: MongoDB stores UTC"
    },
    "mistake_6_inefficient_arithmetic": {
      "mistake": "Manual date math in application",
      "wrong": "new Date(date.getTime() + days*24*60*60*1000)",
      "right": "{ $dateAdd: { startDate: '$date', unit: 'day', amount: days } }",
      "why": "MongoDB handles DST, precision better"
    }
  },
  "section_12_date_operations": {
    "title": "Date Operation Reference",
    "query_operators": [
      {
        "operator": "$gt",
        "use": "After date",
        "example": "enrollmentDate: { $gt: date }"
      },
      {
        "operator": "$gte",
        "use": "On or after date",
        "example": "enrollmentDate: { $gte: date }"
      },
      {
        "operator": "$lt",
        "use": "Before date",
        "example": "enrollmentDate: { $lt: date }"
      },
      {
        "operator": "$lte",
        "use": "On or before date",
        "example": "enrollmentDate: { $lte: date }"
      }
    ],
    "aggregation_operators": [
      {
        "operator": "$year",
        "use": "Extract year",
        "example": "{ $year: '$dateField' }"
      },
      {
        "operator": "$month",
        "use": "Extract month",
        "example": "{ $month: '$dateField' }"
      },
      {
        "operator": "$dayOfMonth",
        "use": "Extract day",
        "example": "{ $dayOfMonth: '$dateField' }"
      },
      {
        "operator": "$dayOfWeek",
        "use": "Day of week (1-7)",
        "example": "{ $dayOfWeek: '$dateField' }"
      },
      {
        "operator": "$dateAdd",
        "use": "Add to date",
        "example": "{ $dateAdd: { startDate, unit, amount } }"
      },
      {
        "operator": "$dateSubtract",
        "use": "Subtract from date",
        "example": "{ $dateSubtract: { startDate, unit, amount } }"
      },
      {
        "operator": "$dateDiff",
        "use": "Difference between dates",
        "example": "{ $dateDiff: { startDate, endDate, unit } }"
      }
    ]
  },
