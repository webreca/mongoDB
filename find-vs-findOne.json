  "summary": {
    "find": "Use when you need multiple documents, searching, filtering, sorting, or pagination",
    "findOne": "Use when you need a single specific document, lookups, or existence checks",
    "key_difference": "find() returns a cursor to multiple documents, findOne() returns single document or null",
    "performance": "findOne is faster for single record lookups, find is necessary for multiple results",
    "best_practice": "Always use findOne for primary key/ID lookups, find for everything else"
  }
