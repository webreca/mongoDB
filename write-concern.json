  "section_9_best_practices": {
    "practice_1_default_is_safe": {
      "practice": "w: 1 (default) is sufficient for most cases",
      "why": "Good balance of safety and performance",
      "use": "Don't change unless specific need"
    },
    "practice_2_use_majority_for_critical": {
      "practice": "Use w: 'majority' for critical data",
      "why": "Ensures data replicated before ack",
      "examples": "Financial, medical, legal data"
    },
    "practice_3_add_journal_for_durability": {
      "practice": "Add j: true for disk persistence",
      "why": "Ensures write persisted to disk",
      "tradeoff": "Add 5-10ms latency"
    },
    "practice_4_always_set_wtimeout": {
      "practice": "Set wtimeout to prevent hangs",
      "why": "Application doesn't wait forever",
      "example": "wtimeout: 5000 (5 seconds)"
    },
    "practice_5_consider_your_sla": {
      "practice": "Match write concern to SLA",
      "why": "Different data different requirements",
      "example": "Financial needs high durability, logs don't"
    },
    "practice_6_test_failover": {
      "practice": "Test write concern during replica failure",
      "why": "Verify behavior when secondaries down",
      "action": "Test with secondaries down, verify timeout"
    }
  },
  "section_10_common_mistakes": {
    "mistake_1_always_using_w0": {
      "mistake": "Always using w: 0 for speed",
      "problem": "Data loss if primary crashes",
      "solution": "Default w: 1 or use w: 'majority' for critical"
    },
    "mistake_2_no_timeout": {
      "mistake": "Not setting wtimeout",
      "problem": "Application hangs if secondaries down",
      "solution": "Always set wtimeout (e.g., 5000ms)"
    },
    "mistake_3_majority_single_server": {
      "mistake": "Using w: 'majority' on single-server (no replicas)",
      "problem": "Majority requires replica set",
      "solution": "Use w: 1 on standalone, w: 'majority' on replicas"
    },
    "mistake_4_wrong_tradeoff": {
      "mistake": "Using w: 0 for critical data",
      "problem": "Financial data lost on crash",
      "solution": "Use w: 'majority' for critical, w: 0 for logs only"
    },
    "mistake_5_ignoring_journal": {
      "mistake": "Using w: 'majority' without j: true",
      "problem": "Data replicated but not journaled",
      "solution": "Add j: true for disk persistence"
    }
  },
  "section_11_deciding_write_concern": {
    "title": "Decision Tree: Which Write Concern?",
    "question_1": "Is data loss acceptable?",
    "yes_logs": "YES (logs, telemetry) → w: 0 (optional)",
    "no_critical": "NO (financial, medical) → w: 'majority'",
    "question_2_after_critical": "Must be persisted to disk?",
    "yes_persistent": "YES → Add j: true",
    "no_replicated": "NO (replication enough) → Just w: 'majority'",
    "question_3_after_normal": "Is speed critical?",
    "yes_fast": "YES (real-time) → w: 1 (default)",
    "no_safe": "NO → w: 'majority' (safer)",
    "final_steps": [
      "Add wtimeout to all (prevent hangs)",
      "Test with failures",
      "Monitor latency impact"
    ]
  },
  "summary": {
    "definition": "Write Concern controls how MongoDB acknowledges writes",
    "key_levels": [
      "w: 0 - No acknowledgment (fire and forget)",
      "w: 1 - Primary acknowledges (default)",
      "w: 'majority' - Majority acknowledges (safest)",
      "w: 'all' - All replicas acknowledge (slowest)"
    ],
    "performance_tradeoff": "Higher w = Safer but Slower",
    "best_practice": "Use w: 1 (default) for normal data, w: 'majority' for critical data",
    "always_add": "wtimeout to prevent hanging",
    "consider_journal": "Add j: true for disk persistence if critical",
    "replica_set_required": "w: 'majority' requires replica set (3+ nodes)"
  }
}
