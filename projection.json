{
  "title": "MongoDB Projection - Complete Use Cases Guide",
  "description": "Comprehensive guide on field projection with practical examples",
  "date": "2024-06-23",
  "totalStudents": 60,
  "projection_overview": {
    "definition": "Projection specifies which fields to include or exclude in query results",
    "purpose": [
      "Reduce network traffic",
      "Improve query performance",
      "Hide sensitive data",
      "Return only needed fields",
      "Save bandwidth"
    ],
    "syntax": "db.collection.find(filter, projection)",
    "projection_format": {
      "include_field": 1,
      "exclude_field": 0
    }
  },
  "section_1_basic_projection": {
    "title": "Basic Projection Concepts",
    "syntax": "db.collection.find(filter, { field1: 1, field2: 1, ... })",
    "include_fields": {
      "value": 1,
      "meaning": "Include this field in result",
      "example": "{ name: 1, gpa: 1 }",
      "result": "Returns only name and gpa (excluding _id unless explicitly removed)"
    },
    "exclude_fields": {
      "value": 0,
      "meaning": "Exclude this field from result",
      "example": "{ libraryCardToken: 0 }",
      "result": "Returns all fields except libraryCardToken"
    },
    "id_field_special": {
      "note": "_id is included by default",
      "explicit_exclude": "{ _id: 0, name: 1, gpa: 1 }",
      "result": "Returns name and gpa without _id"
    },
    "mixed_projection_note": "Cannot mix include and exclude (except _id) in same projection"
  },
  "section_2_include_projections": {
    "title": "Include Specific Fields",
    "description": "Fetch only needed fields, exclude everything else",
    "use_case": "Reduce network traffic by selecting only required fields",
    "examples": [
      {
        "example": "Get names and GPAs only",
        "command": "db.students.find({}, { name: 1, gpa: 1 })",
        "result": "Returns: _id, name, gpa (excludes all others)",
        "size_reduction": "Reduces document from ~650 bytes to ~150 bytes",
        "use_case": "List view showing student names and grades"
      },
      {
        "example": "Get student basic info",
        "command": "db.students.find({}, { name: 1, major: 1, age: 1, _id: 0 })",
        "result": "Returns: name, major, age (no _id)",
        "size_reduction": "Very small documents",
        "use_case": "Quick lookup of student info"
      },
      {
        "example": "Get skills only",
        "command": "db.students.find({}, { skills: 1 })",
        "result": "Returns: _id, skills",
        "use_case": "Skill-based search or filtering"
      },
      {
        "example": "Get contact and location info",
        "command": "db.students.find({}, { name: 1, email: 1, campusLocation: 1 })",
        "result": "Returns: _id, name, email, campusLocation",
        "use_case": "Directory lookup"
      }
    ]
  },
  "section_2b_include_nested": {
    "title": "Include Nested Fields",
    "examples": [
      {
        "example": "Get only first name",
        "command": "db.students.find({}, { 'name.first': 1 })",
        "result": "Returns: _id, name: { first: 'Daksh' }",
        "use_case": "Display first name only"
      },
      {
        "example": "Get location coordinates",
        "command": "db.students.find({}, { 'campusLocation.coordinates': 1 })",
        "result": "Returns: _id, campusLocation: { coordinates: [77.2095, 28.6144] }",
        "use_case": "Map display"
      },
      {
        "example": "Get scholarship amount",
        "command": "db.students.find({}, { 'scholarshipDetails.amount': 1 })",
        "result": "Returns: _id, scholarshipDetails: { amount: 15000 }",
        "use_case": "Financial report"
      }
    ]
  },
  "section_3_exclude_projections": {
    "title": "Exclude Sensitive Fields",
    "description": "Return all fields except sensitive ones",
    "use_case": "Hide sensitive data from results",
    "examples": [
      {
        "example": "Exclude library card token",
        "command": "db.students.find({}, { libraryCardToken: 0 })",
        "result": "Returns all fields except libraryCardToken",
        "use_case": "Display student info without token"
      },
      {
        "example": "Exclude password",
        "command": "db.students.find({}, { password: 0 })",
        "result": "Returns everything except password",
        "use_case": "User profiles (if password field existed)"
      },
      {
        "example": "Exclude multiple sensitive fields",
        "command": "db.students.find({}, { libraryCardToken: 0, password: 0, ssn: 0 })",
        "result": "Returns all except sensitive fields",
        "use_case": "Public-facing API results"
      }
    ]
  },
  "section_4_performance_analysis": {
    "title": "Performance Benefits of Projection",
    "comparison": [
      {
        "scenario": "Fetch all student fields",
        "command": "db.students.find({})",
        "document_size": "~650 bytes per document",
        "total_size_60_students": "~39 KB",
        "network_time": "~50-100ms",
        "use_case": "Complete data export"
      },
      {
        "scenario": "Fetch only names and GPAs",
        "command": "db.students.find({}, { name: 1, gpa: 1 })",
        "document_size": "~150 bytes per document",
        "total_size_60_students": "~9 KB",
        "network_time": "~10-20ms",
        "improvement": "4x smaller, 80% reduction",
        "use_case": "List view"
      },
      {
        "scenario": "Fetch only first names",
        "command": "db.students.find({}, { 'name.first': 1 })",
        "document_size": "~50 bytes per document",
        "total_size_60_students": "~3 KB",
        "network_time": "~5-10ms",
        "improvement": "13x smaller, 92% reduction",
        "use_case": "Autocomplete suggestion"
      }
    ]
  },
  "section_5_real_world_use_cases": {
    "use_case_1_list_view": {
      "title": "Student List View",
      "requirement": "Display table with name, major, GPA",
      "projection": "{ name: 1, major: 1, gpa: 1, _id: 0 }",
      "command": "db.students.find({}, { name: 1, major: 1, gpa: 1, _id: 0 })",
      "result": "60 small documents, ~200 bytes each",
      "benefit": "Minimal network traffic for list display"
    },
    "use_case_2_search_autocomplete": {
      "title": "Autocomplete Student Names",
      "requirement": "Suggest student names as user types",
      "projection": "{ 'name.first': 1, 'name.last': 1 }",
      "command": "db.students.find({ 'name.first': /^[A-Z]/ }, { 'name.first': 1, 'name.last': 1 })",
      "result": "Only names, very fast",
      "benefit": "Fast autocomplete with minimal data"
    },
    "use_case_3_profile_page": {
      "title": "Student Profile Page",
      "requirement": "Display complete student information",
      "projection": "{ libraryCardToken: 0 }",
      "command": "db.students.findOne({ studentId: 20260001 }, { libraryCardToken: 0 })",
      "result": "All student data except sensitive token",
      "benefit": "Hide sensitive fields while showing everything else"
    },
    "use_case_4_map_display": {
      "title": "Campus Map with Student Locations",
      "requirement": "Show student locations on map",
      "projection": "{ name: 1, campusLocation: 1 }",
      "command": "db.students.find({}, { name: 1, campusLocation: 1 })",
      "result": "Only names and coordinates",
      "benefit": "Minimal data needed for map display"
    },
    "use_case_5_api_response": {
      "title": "API Response (Hide Sensitive Data)",
      "requirement": "Return student data to mobile app",
      "projection": "{ libraryCardToken: 0, password: 0 }",
      "command": "db.students.find({}, { libraryCardToken: 0, password: 0 })",
      "result": "All fields except sensitive ones",
      "benefit": "API returns only appropriate data"
    },
    "use_case_6_scholarship_report": {
      "title": "Scholarship Report",
      "requirement": "Show scholarship amounts for financial report",
      "projection": "{ name: 1, 'scholarshipDetails.amount': 1 }",
      "command": "db.students.find({ 'scholarshipDetails.amount': { $exists: true } }, { name: 1, 'scholarshipDetails.amount': 1 })",
      "result": "Only names and scholarship amounts",
      "benefit": "Minimal data for reporting"
    },
    "use_case_7_admin_panel": {
      "title": "Admin Panel - Full Information",
      "requirement": "Show complete student record",
      "projection": "{}",
      "command": "db.students.findOne({ studentId: 20260001 })",
      "result": "All fields included",
      "benefit": "Complete data for administration"
    }
  },
  "section_6_projection_patterns": {
    "pattern_1_minimal": {
      "name": "Minimal Projection",
      "command": "db.students.find({}, { name: 1, _id: 0 })",
      "use_for": "Ultra-fast queries, autocomplete, suggestions"
    },
    "pattern_2_summary": {
      "name": "Summary Projection",
      "command": "db.students.find({}, { name: 1, major: 1, gpa: 1, _id: 0 })",
      "use_for": "List views, tables, quick summaries"
    },
    "pattern_3_exclude_heavy": {
      "name": "Exclude Large Fields",
      "command": "db.students.find({}, { libraryCardToken: 0 })",
      "use_for": "API responses, public data"
    },
    "pattern_4_nested_only": {
      "name": "Nested Field Only",
      "command": "db.students.find({}, { 'scholarshipDetails.amount': 1 })",
      "use_for": "Specific nested information"
    },
    "pattern_5_full_document": {
      "name": "Full Document (No Projection)",
      "command": "db.students.find({})",
      "use_for": "Export, admin views, complete data"
    }
  },
  "section_7_best_practices": [
    {
      "practice": "Use projection to reduce network traffic",
      "example": "db.students.find({}, { name: 1, gpa: 1 })",
      "benefit": "Smaller documents = faster queries and less bandwidth"
    },
    {
      "practice": "Exclude sensitive fields in API responses",
      "example": "db.students.find({}, { libraryCardToken: 0 })",
      "benefit": "Don't expose sensitive data"
    },
    {
      "practice": "Use minimal projection for autocomplete",
      "example": "db.students.find({}, { 'name.first': 1 })",
      "benefit": "Lightning-fast suggestions"
    },
    {
      "practice": "Include _id: 0 when not needed",
      "example": "db.students.find({}, { name: 1, _id: 0 })",
      "benefit": "Slightly smaller documents"
    },
    {
      "practice": "Create indexes on projected fields",
      "example": "db.students.createIndex({ name: 1 })",
      "benefit": "Projection queries use indexes"
    },
    {
      "practice": "Don't over-project (include unnecessary fields)",
      "bad_example": "db.students.find({}, { name: 1, major: 1, gpa: 1, age: 1, email: 1 })",
      "good_example": "db.students.find({}, { name: 1, gpa: 1 })",
      "benefit": "Include only what you actually need"
    }
  ],
  "student_data_projection_examples": {
    "example_1_list_view": {
      "usecase": "Display student roster",
      "projection": "{ name: 1, major: 1, gpa: 1 }",
      "sample_result": [
        { "_id": "...", "name": { "first": "Daksh", "last": "Chauhan" }, "major": "Data Science", "gpa": 3.85 },
        { "_id": "...", "name": { "first": "Anaya", "last": "Sharma" }, "major": "Frontend Engineering", "gpa": 3.92 },
        "... (60 total)"
      ]
    },
    "example_2_name_autocomplete": {
      "usecase": "Autocomplete student names",
      "projection": "{ 'name.first': 1, 'name.last': 1 }",
      "sample_result": [
        { "_id": "...", "name": { "first": "Daksh", "last": "Chauhan" } },
        { "_id": "...", "name": { "first": "Anaya", "last": "Sharma" } }
      ]
    },
    "example_3_hide_sensitive": {
      "usecase": "API response without tokens",
      "projection": "{ libraryCardToken: 0 }",
      "sample_result": "All student fields except libraryCardToken"
    },
    "example_4_map_data": {
      "usecase": "Display on campus map",
      "projection": "{ 'name.first': 1, campusLocation: 1 }",
      "sample_result": [
        { "_id": "...", "name": { "first": "Daksh" }, "campusLocation": { "type": "Point", "coordinates": [77.2095, 28.6144] } }
      ]
    }
  },
  "section_8_common_mistakes": [
    {
      "mistake": "Mixing include and exclude",
      "bad_code": "db.students.find({}, { name: 1, libraryCardToken: 0 })",
      "error": "Cannot mix include and exclude (except _id)",
      "fix": "Use either all includes or all excludes"
    },
    {
      "mistake": "Forgetting performance impact of large fields",
      "bad_code": "db.students.find({}, { libraryCardToken: 1 })",
      "problem": "Unnecessarily includes large binary data",
      "fix": "Only include when needed"
    },
    {
      "mistake": "Including too many fields",
      "bad_code": "db.students.find({}, { field1: 1, field2: 1, ..., field20: 1 })",
      "problem": "Defeats purpose of projection",
      "fix": "Include only necessary fields"
    },
    {
      "mistake": "Not using projection on large result sets",
      "bad_code": "db.students.find({})",
      "problem": "Returns 39KB for all 60 students when only need 3KB",
      "fix": "Always project when fetching multiple records"
    }
  ],
  "summary": {
    "projection": "Specifies which fields to include (1) or exclude (0) in query results",
    "benefits": [
      "Reduced network traffic (4-13x smaller)",
      "Faster query execution",
      "Hide sensitive data",
      "Better performance"
    ],
    "best_practice": "Always use projection - include only the fields you actually need",
    "rule": "Include for lists/APIs, exclude for security, no projection for complete documents"
  }
}
