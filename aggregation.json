        "stages": 5
      }
    ]
  },
  "section_11_performance": {
    "title": "Performance Considerations",
    "early_match": {
      "benefit": "Place $match early to filter data before other stages",
      "example": "[$match, $group] faster than [$group, $match]",
      "impact": "Reduces memory usage, improves speed significantly"
    },
    "indexing": {
      "note": "Indexes help $match performance",
      "recommendation": "Index fields used in $match filters",
      "benefit": "Dramatically speeds up filtering"
    },
    "memory_limits": {
      "note": "Pipeline results stored in memory",
      "limit": "100MB default limit",
      "solution": "Use $limit to reduce data or allowDiskUse: true"
    },
    "allow_disk_use": {
      "syntax": "db.collection.aggregate([...], { allowDiskUse: true })",
      "benefit": "Allows spilling to disk if >100MB",
      "tradeoff": "Slower but handles larger datasets"
    },
    "stage_performance": {
      "$match": "Very fast (uses indexes)",
      "$project": "Fast (field selection)",
      "$group": "Moderate (memory intensive)",
      "$lookup": "Slow (joins other collection)",
      "$sort": "Moderate to slow (can use index)",
      "$unwind": "Moderate (array expansion)"
    }
  },
  "section_12_best_practices": {
    "practice_1_early_match": {
      "rule": "Place $match early in pipeline",
      "good": "[$match, $group, $sort]",
      "avoid": "[$group, $sort, $match]",
      "why": "Reduces documents for following stages"
    },
    "practice_2_project_early": {
      "rule": "Use $project to select needed fields early",
      "good": "[$match, $project, $group]",
      "why": "Reduces memory usage"
    },
    "practice_3_index_for_match": {
      "rule": "Index fields used in $match",
      "example": "db.students.createIndex({ major: 1 })",
      "why": "Speeds up filtering dramatically"
    },
    "practice_4_avoid_unnecessary_stages": {
      "rule": "Minimize pipeline stages",
      "avoid": "Multiple $project or $sort stages",
      "solution": "Combine operations when possible"
    },
    "practice_5_use_allowDiskUse": {
      "rule": "For large datasets, allow spilling to disk",
      "syntax": "aggregate([...], { allowDiskUse: true })",
      "when": "Processing >100MB data"
    }
  },
  "section_13_common_mistakes": {
    "mistake_1_late_match": {
      "mistake": "Placing $match at end of pipeline",
      "problem": "Processes all documents before filtering",
      "solution": "Move $match to beginning"
    },
    "mistake_2_missing_id_in_group": {
      "mistake": "Using fields in $group without referencing",
      "wrong": "{ $group: { _id: '$major', name: '$name' } }",
      "right": "{ $group: { _id: '$major', majorName: { $first: '$name' } } }",
      "why": "Can't reference individual fields in group"
    },
    "mistake_3_reference_syntax": {
      "mistake": "Forgetting $ for field reference",
      "wrong": "{ $group: { _id: major } }",
      "right": "{ $group: { _id: '$major' } }",
      "impact": "Uses literal string instead of field value"
    },
    "mistake_4_memory_overflow": {
      "mistake": "Processing huge dataset without allowDiskUse",
      "problem": "Exceeds 100MB memory limit",
      "solution": "Add { allowDiskUse: true } option"
    },
    "mistake_5_wrong_aggregation_operator": {
      "mistake": "Using $sum instead of $avg for average",
      "wrong": "avgGpa: { $sum: '$gpa' }",
      "right": "avgGpa: { $avg: '$gpa' }",
      "impact": "Returns wrong calculation"
    },
    "mistake_6_lookup_performance": {
      "mistake": "Using $lookup without optimization",
      "problem": "Slow nested loops",
      "solution": "Index foreign key field, use localField optimization"
    }
  },
  "section_14_progression": {
    "beginner": [
      "$match for filtering",
      "$project for field selection",
      "$group for basic aggregation",
      "$sort for ordering"
    ],
    "intermediate": [
      "$group with multiple aggregators",
      "$skip and $limit for pagination",
      "$unwind for array expansion",
      "Multi-stage pipelines"
    ],
    "advanced": [
      "$lookup for joins",
      "$facet for multi-pipeline analysis",
      "Complex pipelines with many stages",
      "Performance optimization",
      "allowDiskUse for large datasets"
    ]
  },
  "summary": {
    "core_stages": [
      "$match - Filter documents",
      "$project - Select/transform fields",
      "$group - Aggregate by groups",
      "$sort - Order results",
      "$skip/$limit - Pagination",
      "$unwind - Expand arrays",
      "$lookup - Join collections",
      "$facet - Multiple pipelines"
    ],
    "key_concepts": [
      "Pipeline processes documents through stages in order",
      "Early $match improves performance",
      "$group requires $ for field references",
      "Indexes help $match and $sort",
      "Memory limit 100MB (use allowDiskUse for more)",
      "Aggregation for complex analytics vs find() for simple queries"
    ],
    "best_practice": "Start with $match, use indexes, minimize stages, plan data flow carefully",
    "progression": "Beginner: Basic stages ($match, $project, $group) → Intermediate: Complex pipelines, pagination → Advanced: Joins, faceting, optimization"
  }
}
