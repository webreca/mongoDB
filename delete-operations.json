      },
      {
        "scenario": "Delete all graduated students",
        "filter": "{ status: 'graduated' }",
        "target": "All graduated records",
        "result": "All matching graduated deleted"
      },
      {
        "scenario": "Delete ALL (DANGER!)",
        "filter": "{}",
        "target": "ALL 60 STUDENTS",
        "result": "60 students deleted 💀"
      }
