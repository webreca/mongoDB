  },
  "summary": {
    "deleteOne": "Use for single document deletion (remove one student)",
    "deleteMany": "Use for multiple document deletion (remove all inactive)",
    "warning": "Both are IRREVERSIBLE without backup",
    "critical_rule": "ALWAYS test filter first with find().count()",
    "backup_rule": "ALWAYS backup before bulk delete",
    "key_point": "Delete operations are dangerous - proceed with extreme caution"
  }
}
